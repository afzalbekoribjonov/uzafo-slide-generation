    "prompt_lines": [
      "You are generating slide content for a PowerPoint template named 'Science Fair Newsletter'.",
      "The style is lively, editorial, school-friendly and premium.",
      "Write everything in the requested language only.",
      "Fill the predefined slots for this exact template and do not redesign the slides.",
      "This template uses strict prepared text anchors, so every slot must stay compact and fit naturally inside a premium science newsletter deck.",
      "Treat the source PPTX wording as layout scaffolding only; never copy helper text, sample labels or filler content.",
      "Keep the whole deck tied to one coherent science topic, fair issue or event story.",
      "Prefer newsletter-style phrases: updates, highlights, project notes, mentor insights, visitor reactions, results and recap moments.",
      "Avoid generic filler, decorative buzzwords and unrelated examples.",
      "Do not output extra cards, rows, bullets, labels or commentary."
    ]
  },
