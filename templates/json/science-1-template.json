    "writing_rules": [
      "Respect slot limits exactly.",
      "Keep headings compact and memorable.",
      "Keep body text concise enough for premium editorial slides.",
      "Do not invent extra cards, rows, bullets or commentary.",
      "Prefer newsletter-style summaries over long explanations."
    ],
